from building import *
import rtconfig
Import('RTT_ROOT')

# get current directory
cwd = GetCurrentDir()

# The set of source files associated with this SConscript file.
src = []

# add for DSP library
src += [cwd + '/DSP/Source/FastMathFunctions/riscv_cos_f32.c',
        cwd + '/DSP/Source/FastMathFunctions/riscv_sin_f32.c',
        cwd + '/DSP/Source/CommonTables/CommonTables.c']

path = [cwd + '/DSP/Include',
        cwd + '/Core/Include',
        cwd + '/DSP/PrivateInclude']

group = DefineGroup('NMSIS_DSP', src, depend=[''], CPPPATH=path)

Return('group')
