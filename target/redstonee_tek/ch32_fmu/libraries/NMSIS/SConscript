import rtconfig
Import('RTT_ROOT')
from building import *

# get current directory
cwd = GetCurrentDir()

# The set of source files associated with this SConscript file.
src = []

#add for DSP library
src += Glob('DSP/Source/FastMathFunctions/*f32.c')
src += Glob('DSP/Source/BasicMathFunctions/*f32.c')
src += Glob('DSP/Source/MatrixFunctions/*f32.c')
src += Glob('DSP/Source/SupportFunctions/*f32.c')

path = [cwd + '/DSP/Include', cwd + '/Core/Include']
group = DefineGroup('NMSIS_DSP', src, depend = [''], CPPPATH = path)

Return('group')
